# Define a class
class Student:
    
    # Constructor
    def __init__(self, name, course):
        self.name = name
        self.course = course
    
    # Method
    def study(self):
        print(self.name + " is studying " + self.course)
    
    def display_info(self):
        print("Name:", self.name)
        print("Course:", self.course)


# Create objects
student1 = Student("Tasha", "Computer Science")
student2 = Student("Brian", "Business")

# Use object methods
student1.display_info()
student1.study()

print()  # space

student2.display_info()
student2.study()
